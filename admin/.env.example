# ─── STANDALONE ADMIN (bo-backoffice.site) ───────────────────────────────────────

# Upload entire admin/ folder contents to /www/wwwroot/bo-backoffice.site/

# cp .env.example .env  →  fill values below



APP_ENV=production

APP_DEBUG=false

APP_KEY=CHANGE-ME-32-CHARS-MINIMUM-ADMIN-KEY!!



METROPOL_ROOT=/www/wwwroot/bo-backoffice.site

ADMIN_URL_PREFIX=



BACKEND_HOST=bo-backoffice.site

BACKEND_URL=https://bo-backoffice.site

BACKEND_API_BASE_URL=https://api.bo-backoffice.site/api/v2

API_BACKEND_MAIN_BASE_URL=https://api.bo-backoffice.site/api/v2

API_BACKEND_FALLBACK_BASE_URL=https://bo-backoffice.site/api/v2



SITE_URL=https://vegasroyalspin.com

FRONTEND_URL=https://vegasroyalspin.com

FRONTEND_FALLBACK_URL=https://vegasroyalspin.com

PUBLIC_URL_HOSTS=vegasroyalspin.com,www.vegasroyalspin.com,m.vegasroyalspin.com

ALLOWED_URL_HOSTS=vegasroyalspin.com,www.vegasroyalspin.com,m.vegasroyalspin.com,bo-backoffice.site,api.bo-backoffice.site

DEFAULT_ALLOWED_URL_HOSTS=vegasroyalspin.com,www.vegasroyalspin.com,m.vegasroyalspin.com,bo-backoffice.site,api.bo-backoffice.site,api.bo-backoffice.site



# Must match frontend .env exactly

MEMBER_JWT_SECRET=CHANGE-ME-SAME-ON-BOTH-HOSTS-32-CHARS!!



LIVE_SUPPORT_URL=https://direct.lc.chat/19301899/



# MySQL — admin host ONLY (frontend must NOT have these)

DB_HOST=127.0.0.1

DB_PORT=3306

DB_DATABASE=metropol_db

DB_USERNAME=metropol_user

DB_PASSWORD=CHANGE-ME



ALLOW_RUNTIME_MIGRATIONS=0

METROPOL_RUNTIME_PROVIDER_BOOTSTRAP=0



# Provider secrets (configure in admin panel or here)

BGAMING_WALLET_SECRET=

MEGAPAYZ_PRIVATE_KEY=

MEGAPAYZ_CALLBACK_TOKEN=

