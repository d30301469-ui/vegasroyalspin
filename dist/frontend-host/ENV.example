# ─── FRONTEND (vegasroyalspin.com + m.vegasroyalspin.com) ───────────────────
# Cloudflare edge SSL: CLOUDFLARE_SSL=1, ORIGIN_HTTP=1, aaPanel Force HTTPS OFF.
# Fix: php deploy/aapanel/fix-cloudflare-env.php

# Upload dist/frontend-host/* → /www/wwwroot/vegasroyalspin.com/

# aaPanel: m.vegasroyalspin.com alias → same document root

# cp ENV.example .env  →  fill MEMBER_JWT_SECRET (must match bo-nexthub.site)



APP_ENV=production

APP_DEBUG=false

CLOUDFLARE_SSL=1

ORIGIN_HTTP=1

APP_KEY=CHANGE-ME-32-CHARS-MINIMUM-FRONTEND!!



FRONTEND_API_ONLY=1



SITE_URL=https://vegasroyalspin.com

FRONTEND_URL=https://vegasroyalspin.com

FRONTEND_FALLBACK_URL=https://vegasroyalspin.com

SESSION_COOKIE_DOMAIN=.vegasroyalspin.com



BACKEND_HOST=bo-nexthub.site

BACKEND_URL=https://bo-nexthub.site

BACKEND_FALLBACK_URL=https://bo-nexthub.site

BACKEND_API_BASE_URL=https://api.bo-nexthub.site/api/v2

API_BACKEND_MAIN_BASE_URL=https://api.bo-nexthub.site/api/v2

API_BACKEND_FALLBACK_BASE_URL=https://bo-nexthub.site/api/v2

# Loopback artık zorunlu değil — api subdomain kullanın. Aynı sunucudaysa isteğe bağlı:
# API_BACKEND_INTERNAL_BASE_URL=http://127.0.0.1/api/v2
# API_BACKEND_INTERNAL_HOST=bo-nexthub.site



PUBLIC_URL_HOSTS=vegasroyalspin.com,www.vegasroyalspin.com,m.vegasroyalspin.com

ALLOWED_URL_HOSTS=vegasroyalspin.com,www.vegasroyalspin.com,m.vegasroyalspin.com,bo-nexthub.site,api.bo-nexthub.site

DEFAULT_ALLOWED_URL_HOSTS=vegasroyalspin.com,www.vegasroyalspin.com,m.vegasroyalspin.com,bo-nexthub.site,api.bo-nexthub.site



# Must match backend (bo-nexthub.site) .env exactly

MEMBER_JWT_SECRET=CHANGE-ME-SAME-ON-BOTH-HOSTS-32-CHARS!!

# Must match backend — receives POST /api/v2/internal/cms-cache-purge from admin saves

FRONTEND_CMS_PURGE_SECRET=CHANGE-ME-SAME-ON-BOTH-HOSTS-PURGE-SECRET!!

FRONTEND_DIRECT_MEMBER_API=0

FRONTEND_MEMBER_API_CIRCUIT_SECONDS=0

FRONTEND_API_PROXY_TIMEOUT=60



LIVE_SUPPORT_URL=https://direct.lc.chat/19301899/

WHATSAPP_URL=

TELEGRAM_URL=https://t.me



# Frontend host: NO database credentials (API-only)

ALLOW_RUNTIME_MIGRATIONS=0

METROPOL_RUNTIME_PROVIDER_BOOTSTRAP=0

