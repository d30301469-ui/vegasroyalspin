# Environment example — production split-host defaults
# (vegasroyalspin.com + admin.vegasroyalspin.com + api.vegasroyalspin.com)
# Copy deploy/env/frontend.vegasroyalspin.env.example or deploy/env/backend.env.example for deploy.

APP_ENV=production
APP_DEBUG=false

SITE_URL=https://vegasroyalspin.com
FRONTEND_URL=https://vegasroyalspin.com
FRONTEND_FALLBACK_URL=https://vegasroyalspin.com

BACKEND_HOST=admin.vegasroyalspin.com
BACKEND_URL=https://admin.vegasroyalspin.com
BACKEND_FALLBACK_URL=https://admin.vegasroyalspin.com

PUBLIC_URL_HOSTS=vegasroyalspin.com,www.vegasroyalspin.com,m.vegasroyalspin.com
ALLOWED_URL_HOSTS=vegasroyalspin.com,www.vegasroyalspin.com,m.vegasroyalspin.com,admin.vegasroyalspin.com,api.vegasroyalspin.com
DEFAULT_ALLOWED_URL_HOSTS=vegasroyalspin.com,www.vegasroyalspin.com,m.vegasroyalspin.com,admin.vegasroyalspin.com,api.vegasroyalspin.com

SESSION_COOKIE_DOMAIN=.vegasroyalspin.com

BACKEND_API_BASE_URL=https://api.vegasroyalspin.com/api/v2
API_BACKEND_MAIN_BASE_URL=https://api.vegasroyalspin.com/api/v2
API_BACKEND_FALLBACK_BASE_URL=https://admin.vegasroyalspin.com/api/v2
API_BACKEND_SLIDER_BASE_URL=
API_BACKEND_AFFILIATE_BASE_URL=
API_BACKEND_CASINO_WALLET_BASE_URL=
API_BACKEND_PAYMENT_CALLBACK_BASE_URL=
API_BACKEND_GAMES_BASE_URL=
API_BACKEND_AUTH_HEADER=
API_BACKEND_CURL_CAINFO=

FRONTEND_API_ONLY=1
FRONTEND_DIRECT_MEMBER_API=1
FRONTEND_MEMBER_API_CIRCUIT_SECONDS=0
FRONTEND_API_PROXY_TIMEOUT=60
FRONTEND_PUBLIC_API_CACHE_TTL=30
FRONTEND_PUBLIC_API_CACHE_STALE=300

APP_KEY=change-me-to-a-random-32-byte-secret
MEMBER_JWT_SECRET=change-me-to-a-different-random-32-byte-secret
FRONTEND_CMS_PURGE_SECRET=change-me-to-a-different-random-32-byte-purge-secret
CSRF_TOKEN_KEY=site_csrf_token

LIVE_SUPPORT_URL=https://direct.lc.chat/19301899/
WHATSAPP_URL=
TELEGRAM_URL=https://t.me

# Production requirements:
# - APP_KEY and MEMBER_JWT_SECRET must be unique, non-placeholder values with at least 32 characters.
# - Never deploy with root database users or empty database credentials on the backend host.
# - Set ALLOW_RUNTIME_MIGRATIONS=0 and METROPOL_RUNTIME_PROVIDER_BOOTSTRAP=0 in production.
# - api.vegasroyalspin.com must share the same document root as admin.vegasroyalspin.com (alias, not /api subfolder).

ALLOW_RUNTIME_MIGRATIONS=0
METROPOL_RUNTIME_PROVIDER_BOOTSTRAP=0

BGAMING_WALLET_SECRET=
MEGAPAYZ_PRIVATE_KEY=
MEGAPAYZ_CALLBACK_TOKEN=
MEGAPAYZ_CALLBACK_ALLOWED_IPS=
CASINO_CALLBACK_ALLOWED_IPS=
MEGAPAYZ_API_BASE_URL=https://api.megapayz.net
BGAMING_API_BASE_URL=https://int.bgaming-system.com

OKKO_SPORTS_API_KEY=
OKKO_SPORTS_API_SECRET=

CASINO_API_URL=
CASINO_AGENT_CODE=
CASINO_API_TOKEN=

# Backend host only — do NOT set DB_* on the frontend host (FRONTEND_API_ONLY=1)
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=metropol_db
DB_USERNAME=metropol_user
DB_PASSWORD=

DATABASE_HOST=
DATABASE_PORT=
DATABASE_NAME=
DATABASE_USERNAME=
DATABASE_PASSWORD=
DATABASE_CHARSET=

ADMIN_DB_HOST=
ADMIN_DB_PORT=
ADMIN_DB_DATABASE=
ADMIN_DB_USERNAME=
ADMIN_DB_PASSWORD=
ADMIN_DB_CHARSET=

METROPOL_ROOT=/www/wwwroot/admin.vegasroyalspin.com
ADMIN_URL_PREFIX=

# Cloudflare edge SSL (aaPanel origin HTTP):
# CLOUDFLARE_SSL=1
# ORIGIN_HTTP=1
# API_BACKEND_INTERNAL_BASE_URL=http://127.0.0.1/api/v2
# API_BACKEND_INTERNAL_HOST=admin.vegasroyalspin.com
# php deploy/aapanel/fix-cloudflare-env.php
