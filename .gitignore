# ----------------------------
# OS / Editor
# ----------------------------
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo

# ----------------------------
# Env / Secrets
# ----------------------------
.env
.env.*
!.env.example
!ENV.example
admin/.env
admin/.env.*
!admin/.env.example
*.pem
*.key
*.crt
temp_env_dump.txt

# ----------------------------
# Dependency dirs
# ----------------------------
vendor/
node_modules/

# ----------------------------
# Logs
# ----------------------------
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pages/error.log
storage/logs/*
!storage/logs/.gitkeep
admin/storage/logs/*
!admin/storage/logs/.gitkeep

# ----------------------------
# Runtime cache / generated files
# ----------------------------
storage/cache/**
!storage/cache/cms/.gitkeep
admin/storage/cache/**
!admin/storage/cache/cms/.gitkeep

# lock/refresh artifacts generated on server
*.refresh.lock

# reports generated at runtime
storage/reports/*.json
admin/storage/reports/*.json

# uploads (runtime)
storage/uploads/**
!storage/uploads/.gitkeep
admin/storage/uploads/**
!admin/storage/uploads/.gitkeep

# ----------------------------
# Build / temp artifacts
# ----------------------------
*.tmp
*.temp
*.bak
*.backup
*.orig

# keep backup files out of git
*.bak.*
.env.bak.*
admin/.env.production.bak

# ----------------------------
# Python artifacts (repo has some py scripts)
# ----------------------------
__pycache__/
*.pyc
.pytest_cache/

# ----------------------------
# PowerShell artifacts
# ----------------------------
*.ps1xml
