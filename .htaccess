<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /

    # Detect backend/API host generically: api.* or admin.* subdomain prefix
    # No hardcoded domain names — works for any deployment
    SetEnvIfNoCase Host "^(?:api|admin)\." IS_BACKEND_HOST=1

    # Bearer token pass-through (Apache strips Authorization by default)
    RewriteCond %{HTTP:Authorization} .
    RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]

    # CMS uploads: /uploads/* → storage/uploads/*
    # IMPORTANT: use END so rewritten /storage/uploads/* does not hit private-path deny rules.
    RewriteRule ^uploads/(.*)$ storage/uploads/$1 [END]

    # Backward compatibility for stale asset links containing /public prefix.
    # Prevents JS/CSS/image 404 + MIME=text/html errors when old URLs are cached
    # or stored in CMS settings.
    RewriteRule ^public/assets/(.*)$ assets/$1 [L,NC]
    RewriteRule ^public/uploads/(.*)$ uploads/$1 [L,NC]

    # ─── Provider webhooks — host-independent ────────────────────────
    # Game/payment providers call the canonical backend_url (the BARE backend
    # domain, e.g. bo-nexthub.site) which does NOT carry the api./admin. prefix,
    # so these MUST NOT be gated by IS_BACKEND_HOST. Each endpoint is protected
    # by signature/IP verification inside PHP.
    RewriteRule ^api/v2/bgaming-wallet/?(.*)$ admin/api/v2/bgaming_callback.php?endpoint=$1 [END,QSA]
    RewriteRule ^api/v2/bgaming/?(.*)$ admin/api/v2/bgaming_callback.php?endpoint=$1 [END,QSA]
    RewriteRule ^api/v2/megapayz-callback/?$ admin/index.php [END,QSA]
    RewriteRule ^drakon_api/?$ admin/index.php [END,QSA]
    RewriteRule ^api/v2/drakon_callback/?$ admin/index.php [END,QSA]
    RewriteRule ^sportsbook_api/?$ admin/index.php [END,QSA]
    RewriteRule ^api/v2/sportsbook-wallet/?$ admin/api/v2/sportsbook_callback.php [END,QSA]

    # ─── Private paths: never serve directly from webroot ─────────────────────
    RewriteRule ^(?:app|bin|config|database|docs|logs|repositories|scripts|services|storage|tests|tools|vendor)(?:/|$) - [F,L]

    # Block project metadata, generated output, and credential/token artifacts from root docroot deployments.
    RewriteRule ^(?:\.env(?:\..*)?|env|ENV\.example|composer\.(?:json|lock)|phpunit\.xml|jwt\.txt|test-output\.txt|phpunit_[^/]+\.txt|README\.md|CICD_SETUP_GUIDE\.md|GLOBAL_ARCHITECTURE_GUIDE\.md|GUNCEL_SISTEM_ANALIZ_RAPORU\.md)$ - [F,L,NC]
    RewriteRule (^|/)\.env(?:\..*)?$ - [F,L,NC]
    RewriteRule (^|/)\.(?!well-known(?:/|$)) - [F,L,NC]

    # Block sensitive file types anywhere, including stray logs/dumps outside private dirs.
    RewriteRule (^|/)[^/]+\.(?:log|sql|sqlite|db|bak|backup|old|orig|save|swp|tmp|env|ini|conf|config|pem|key|crt|p12|pfx|ps1|sh|bat|cmd|py|zip|tar|gz|tgz|7z|rar)$ - [F,L,NC]

    # Allow public uploads such as images, but never executable/server/data artifacts.
    RewriteRule ^uploads/.*\.(?:php[0-9]?|phtml|phar|cgi|pl|py|sh|bat|cmd|ps1|asp|aspx|jsp|html?|js|json|xml|svg|sql|log|ini|env|pem|key|zip|tar|gz|tgz|7z|rar)$ - [F,L,NC]

    # API routing handled by api/.htaccess (deepest-first processing)


    # Admin API implementation files are backend-host only; public API uses /api/v2 via front controllers.
    RewriteCond %{ENV:IS_BACKEND_HOST} !1
    RewriteRule ^admin/api/v2(?:/|$) - [F,L]

    # Backend host (api.* and admin.* subdomains) → admin/api/v2 entry point
    # Direct api/v2 requests
    RewriteCond %{ENV:IS_BACKEND_HOST} 1
    RewriteRule ^api/v2/(.+)$ admin/api/v2/index.php?route=$1 [END,QSA]
    RewriteCond %{ENV:IS_BACKEND_HOST} 1
    RewriteRule ^api/v2/?$ admin/api/v2/index.php [END,QSA]

    # Map api/member/... -> admin/api/v2/index.php?route=...
    RewriteCond %{ENV:IS_BACKEND_HOST} 1
    RewriteRule ^api/member/(.+)$ admin/api/v2/index.php?route=$1 [END,QSA]

    # Map api/content/... -> admin/api/v2/index.php?route=content/...
    RewriteCond %{ENV:IS_BACKEND_HOST} 1
    RewriteRule ^api/content/(.+)$ admin/api/v2/index.php?route=content/$1 [END,QSA]

    # Legacy routes mapped directly to api/v2 routes
    RewriteCond %{ENV:IS_BACKEND_HOST} 1
    RewriteRule ^api/sliders(?:\.php)?$ admin/api/v2/index.php?route=content/sliders [END,QSA]
    RewriteCond %{ENV:IS_BACKEND_HOST} 1
    RewriteRule ^api/auth-sliders(?:\.php)?$ admin/api/v2/index.php?route=content/auth-sliders [END,QSA]
    RewriteCond %{ENV:IS_BACKEND_HOST} 1
    RewriteRule ^api/site-settings(?:\.php)?$ admin/api/v2/index.php?route=site_settings.php [END,QSA]
    RewriteCond %{ENV:IS_BACKEND_HOST} 1
    RewriteRule ^api/winners(?:\.php)?$ admin/api/v2/index.php?route=winners.php [END,QSA]
    RewriteCond %{ENV:IS_BACKEND_HOST} 1
    RewriteRule ^api/announcements(?:\.php)?$ admin/api/v2/index.php?route=announcements.php [END,QSA]
    RewriteCond %{ENV:IS_BACKEND_HOST} 1
    RewriteRule ^api/track-visit(?:\.php)?$ admin/api/v2/index.php?route=track_visit.php [END,QSA]
    RewriteCond %{ENV:IS_BACKEND_HOST} 1
    RewriteRule ^api/games(?:\.php)?$ admin/api/v2/index.php?route=games [END,QSA]
    RewriteCond %{ENV:IS_BACKEND_HOST} 1
    RewriteRule ^api/games-provider(?:\.php)?$ admin/api/v2/index.php?route=games_provider.php [END,QSA]
    RewriteCond %{ENV:IS_BACKEND_HOST} 1
    RewriteRule ^api/footer(?:\.php)?$ admin/api/v2/index.php?route=content/footer [END,QSA]
    RewriteCond %{ENV:IS_BACKEND_HOST} 1
    RewriteRule ^api/mobile-menu(?:\.php)?$ admin/api/v2/index.php?route=content/mobile-menu [END,QSA]
    RewriteCond %{ENV:IS_BACKEND_HOST} 1
    RewriteRule ^api/homepage-sections(?:\.php)?$ admin/api/v2/index.php?route=content/homepage-sections [END,QSA]
    RewriteCond %{ENV:IS_BACKEND_HOST} 1
    RewriteRule ^api/promotions(?:\.php)?$ admin/api/v2/index.php?route=content/promotions [END,QSA]
    RewriteCond %{ENV:IS_BACKEND_HOST} 1
    RewriteRule ^api/footer-pages(?:\.php)?$ admin/api/v2/index.php?route=content/footer-pages [END,QSA]

    # Catch-all for any other /api/... requests on backend hosts
    RewriteCond %{ENV:IS_BACKEND_HOST} 1
    RewriteRule ^api/(.+)$ admin/api/v2/index.php?route=$1 [END,QSA]

    RewriteCond %{ENV:IS_BACKEND_HOST} 1
    RewriteRule ^(.+)\.html$ admin/index.php [END,QSA]

    RewriteCond %{ENV:IS_BACKEND_HOST} 1
    RewriteCond %{DOCUMENT_ROOT}/admin/$1 -f [OR]
    RewriteCond %{DOCUMENT_ROOT}/admin/$1 -d
    RewriteRule ^(.+)$ admin/$1 [END]

    RewriteCond %{ENV:IS_BACKEND_HOST} 1
    RewriteRule ^$ admin/index.php [END,QSA]

    RewriteCond %{ENV:IS_BACKEND_HOST} 1
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^.*$ admin/index.php [END,QSA]

    # ─── /admin/* panel route'ları ───────────────────────────────────
    RewriteRule ^admin/app/ - [F,L]
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^admin(?:/.*)?$ admin/index.php [L,QSA]

    # ─── Dahili PHP dosyalarına doğrudan erişimi engelle ────────────
    # (inc/ ve partials/ içindeki JS/CSS/font gibi statik dosyalar serbest)
    RewriteRule ^core/.*\.php$        - [F,L]
    RewriteRule ^controllers/.*\.php$ - [F,L]
    RewriteRule ^config/.*\.php$      - [F,L]
    RewriteRule ^views/.*\.php$       - [F,L]
    # inc/*.php engelle (API artık /api/winners vb. üzerinden)
    RewriteRule ^inc/.*\.php$ - [F,L]
    RewriteRule ^includes/.*\.php$    - [F,L]
    RewriteRule ^partials/.*\.php$    - [F,L]
    RewriteRule ^pages/.*\.php$       - [F,L]

    RewriteRule ^gold_api/?$ gold_api/api.php [L]
    RewriteRule ^tbs2/?$ tbs2/api.php [L]
    RewriteRule ^r/([a-zA-Z0-9_-]+)$ signup_tracker.php?ref=$1 [L,QSA]

    # ─── Sanal API yolları: api/ gerçek helper klasörü olsa bile public API
    #     istekleri front controller tarafından karşılanır. Aksi halde alt dizin
    #     kurulumlarında Apache gerçek api/ klasörüne düşüp 403 üretebilir.
    RewriteRule ^api/ public/index.php [L,QSA]

    # ─── Gerçek dosyalar dokunma; dizinleri front controller'a bırak ──
    # (footer/ gibi gerçek dizinler -d ile doğrudan servis edilip -Indexes/
    #  DirectorySlash Off yüzünden 403/500 üretmesin diye SADECE -f kontrol edilir.)
    RewriteCond %{REQUEST_FILENAME} -f
    RewriteRule ^ - [L]

    # ─── Her şeyi Front Controller'a yönlendir ──────────────────────
    RewriteRule ^(.*)$ public/index.php [END,QSA]
</IfModule>

<IfModule mod_dir.c>
    DirectorySlash Off
</IfModule>

<IfModule mod_mime.c>
    AddType image/svg+xml .svg .svgz
    AddEncoding gzip .svgz
</IfModule>

DirectoryIndex index.php
Options -Indexes
