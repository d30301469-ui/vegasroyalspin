{
  "name": "metropol/casino",
  "description": "Metropol Casino web application",
  "type": "project",
  "require": {
    "php": ">=8.0",
    "guzzlehttp/guzzle": "^7.0"
  },
  "require-dev": {
    "phpunit/phpunit": "^9.6"
  },
  "autoload": {
    "psr-4": {
      "App\\\\": "app/",
      "Services\\\\": "services/",
      "Controllers\\\\": "controllers/"
    },
    "classmap": [
      "api/",
      "admin/"
    ]
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\\\": "tests/"
    }
  },
  "scripts": {
    "test": "vendor/bin/phpunit",
    "generate-jwt": "php scripts/generate_jwt.php"
  }
}
