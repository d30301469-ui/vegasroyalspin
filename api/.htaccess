# /api — security + v2 front controller routing.
<IfModule mod_authz_core.c>
    Require all granted
</IfModule>
<IfModule !mod_authz_core.c>
    Allow from all
</IfModule>

<IfModule mod_rewrite.c>
    RewriteEngine On

    # Bearer token pass-through (Apache strips Authorization by default)
    RewriteCond %{HTTP:Authorization} .
    RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]

    RewriteRule (^|/)\.(?!well-known(?:/|$)) - [F,L,NC]
    RewriteRule (^|/)[^/]+\.(?:log|sql|sqlite|db|bak|backup|old|orig|save|swp|tmp|env|ini|conf|config|pem|key|crt|p12|pfx|ps1|sh|bat|cmd|py|zip|tar|gz|tgz|7z|rar)$ - [F,L,NC]

    # Monorepo deployment: admin/api/v2/index.php exists → route all v2/* requests to it.
    # Works for any domain (frontend, api subdomain, admin subdomain) without hardcoded names.
    RewriteCond %{DOCUMENT_ROOT}/admin/api/v2/index.php -f
    RewriteRule ^v2/(.+)$ ../admin/api/v2/index.php?route=$1 [END,QSA]
    RewriteCond %{DOCUMENT_ROOT}/admin/api/v2/index.php -f
    RewriteRule ^v2/?$ ../admin/api/v2/index.php [END,QSA]

    # Standalone deployment fallback: no admin panel → use local api/v2/index.php
    RewriteRule ^v2/?$ v2/index.php [L,QSA]
    RewriteRule ^v2/(.+)$ v2/index.php?route=$1 [L,QSA]
</IfModule>