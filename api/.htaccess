# /api — güvenlik + v2 front controller. Panel yönlendirmesi kök .htaccess'te yapılır.
<IfModule mod_authz_core.c>
    Require all granted
</IfModule>
<IfModule !mod_authz_core.c>
    Allow from all
</IfModule>

<IfModule mod_rewrite.c>
    RewriteEngine On

    # Bearer token pass-through (Apache strips Authorization by default)
    RewriteCond %{HTTP:Authorization} .
    RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]

    RewriteRule (^|/)\.(?!well-known(?:/|$)) - [F,L,NC]
    RewriteRule (^|/)[^/]+\.(?:log|sql|sqlite|db|bak|backup|old|orig|save|swp|tmp|env|ini|conf|config|pem|key|crt|p12|pfx|ps1|sh|bat|cmd|py|zip|tar|gz|tgz|7z|rar)$ - [F,L,NC]

    # Üye API v2 — CORS burada işlenir (api/v2/index.php)
    RewriteRule ^v2/?$ v2/index.php [L,QSA]
    RewriteRule ^v2/(.+)$ v2/index.php?route=$1 [L,QSA]

    # Monorepo: docroot/admin/index.php varsa eski /api yolları (v2 hariç) panele
    RewriteCond %{DOCUMENT_ROOT}/admin/index.php -f
    RewriteCond %{HTTP_HOST} ^(?:bo-nexthub\.site|api\.bo-nexthub\.site)(?::[0-9]+)?$ [NC]
    RewriteRule ^(?!v2(?:/|$)).*$ ../admin/index.php [QSA,L]
</IfModule>
